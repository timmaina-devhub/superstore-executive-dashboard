    <worksheet name='TotalSales_KPI'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#9e9e9e' fontname='Sitka Subheading' fontsize='10'>Total Sales</run>
