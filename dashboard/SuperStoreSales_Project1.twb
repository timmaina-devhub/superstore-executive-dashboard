            <column caption='Choose year' datatype='integer' default-format='n0;-0' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='2020'>
              <calculation class='tableau' formula='2020' />
            </column>
            <column caption='choose Category' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Office Supplies&quot;'>
              <calculation class='tableau' formula='&quot;Office Supplies&quot;' />
            </column>
            <column caption='choose region' datatype='string' name='[Parameter 3]' param-domain-type='list' role='measure' type='nominal' value='&quot;East&quot;'>
              <calculation class='tableau' formula='&quot;East&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0d58g38142ado618xoddv0dkhc5y'>
            <column caption='future_growth_profits' datatype='real' name='[Calculation_0116602095947782]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_0238372417953797])-SUM([Calculation_0238372417605636])) / SUM([Calculation_0238372417605636])' />
            </column>
            <column caption='future_growth_profits_isnull' datatype='real' name='[Calculation_0116602096590855]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='If  ISNULL([Calculation_0116602095947782]) THEN 0 ELSE [Calculation_0116602095947782] END' />
            </column>
            <column caption='2020profits' datatype='integer' name='[Calculation_0238372417605636]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) == 2020 THEN [Profit] END' />
            </column>
            <column caption='future profits' datatype='real' name='[Calculation_0238372417953797]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if YEAR([Order Date (profit_prophet_df.csv+)]) &gt;= 2021 THEN [Profit (profit_prophet_df.csv+)] END' />
            </column>
            <column datatype='date' name='[Order Date (profit_prophet_df.csv+)]' role='dimension' type='ordinal' />
