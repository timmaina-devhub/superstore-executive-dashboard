            </column>
            <column caption='Year Over Year Growth' datatype='real' name='[Calculation_0557769491566594]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_0744685495193603]) - SUM([Calculation_0502518363623424]) ) / SUM([Calculation_0502518363623424])' />
            </column>
            <column caption='show yr sales' datatype='integer' name='[Calculation_0744685495193603]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if [Parameters].[Parameter 1] = YEAR([Order Date]) then [Sales] END' />
            </column>
