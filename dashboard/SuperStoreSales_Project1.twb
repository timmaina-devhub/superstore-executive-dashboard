    <worksheet name='ForecastedProfits_KPI'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#d4d4d4' fontname='Sitka Subheading' fontsize='10'>Forecasted Profits</run>
