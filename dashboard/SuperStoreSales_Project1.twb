    <worksheet name='TotalSales_KPI'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#919191' fontname='Sitka Subheading' fontsize='10'>Total Sales</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000'>Total Sales</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='SuperStore_Project' name='federated.1g4xwe802btlr615fh1540mymxtq' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Choose year' datatype='integer' default-format='n0;-0' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='2020'>
              <calculation class='tableau' formula='2020' />
            </column>
            <column caption='choose Category' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Office Supplies&quot;'>
              <calculation class='tableau' formula='&quot;Office Supplies&quot;' />
            </column>
            <column caption='choose region' datatype='string' name='[Parameter 3]' param-domain-type='list' role='measure' type='nominal' value='&quot;East&quot;'>
              <calculation class='tableau' formula='&quot;East&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1g4xwe802btlr615fh1540mymxtq'>
            <column caption='show category selected' datatype='string' name='[Calculation_0135843284992003]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 2] == [Category] then [Category] END' />
            </column>
            <column caption='show region selected' datatype='string' name='[Calculation_0135843313754129]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 3] == [Region] then [Region] END' />
            </column>
            <column caption='previous yr sales' datatype='integer' name='[Calculation_0502518363623424]' role='dimension' type='quantitative'>
              <calculation class='tableau' formula='if [Parameters].[Parameter 1] -1 =YEAR([Order Date]) then [Sales] END' />
            </column>
            <column caption='previous yr' datatype='integer' datatype-customized='true' name='[Calculation_0502518365290497]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1] -1' />
            </column>
            <column caption='KPI Trend color' datatype='string' name='[Calculation_0509392074977281]' role='measure' type='nominal'>
              <calculation class='tableau' formula='if [Calculation_0557769491566594] &gt; 0 THEN &apos;Green&apos; ELSEIF [Calculation_0557769491566594] &lt; 0 THEN &apos;Red&apos; ELSE &apos;Gray&apos; END' />
            </column>
            <column caption='YoY if null' datatype='real' name='[Calculation_0509392078204930]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='If  ISNULL([Calculation_0557769491566594]) THEN 0 ELSE [Calculation_0557769491566594] END' />
            </column>
            <column caption='show sub-category for chosen category' datatype='string' name='[Calculation_0534679495311361]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='if [Parameters].[Parameter 2] = [Category] then [Sub-Category] END' />
            </column>
            <column caption='Year Over Year Growth' datatype='real' name='[Calculation_0557769491566594]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_0744685495193603]) - SUM([Calculation_0502518363623424]) ) / SUM([Calculation_0502518363623424])' />
            </column>
            <column caption='show yr sales' datatype='integer' name='[Calculation_0744685495193603]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if [Parameters].[Parameter 1] = YEAR([Order Date]) then [Sales] END' />
            </column>
            <column caption='Category1' datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column caption='Region1' datatype='string' name='[Region]' role='dimension' type='nominal' />
            <column datatype='integer' datatype-customized='true' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Sales]' role='dimension' type='quantitative' />
            <column caption='State1' datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column datatype='string' name='[Sub-Category]' role='dimension' type='nominal' />
            <column-instance column='[Order Date]' derivation='Month' name='[mn:Order Date:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Sales]' derivation='Sum' name='[sum:Sales:qk]' pivot='key' type='quantitative' />
