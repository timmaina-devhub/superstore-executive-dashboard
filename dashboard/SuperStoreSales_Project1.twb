    <worksheet name='ForecastedProfits_KPI'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#919191' fontname='Sitka Subheading' fontsize='10'>Forecasted Profits</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000'>Total Sales</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='SuperStore_Project' name='federated.1g4xwe802btlr615fh1540mymxtq' />
