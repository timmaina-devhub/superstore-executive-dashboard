              <calculation class='tableau' formula='(SUM([historical sales (copy)_0238372408348673])-SUM([Calculation_0238372412952578])) / SUM([Calculation_0238372412952578])' />
            </column>
            <column caption='forecast_growth_isnull' datatype='real' name='[Calculation_0116602081091587]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='If  ISNULL([Calculation_0116602080985090]) THEN 0 ELSE [Calculation_0116602080985090] END' />
            </column>
            <column caption='2020SALES' datatype='integer' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Calculation_0238372412952578]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) == 2020 THEN [Sales] END' />
