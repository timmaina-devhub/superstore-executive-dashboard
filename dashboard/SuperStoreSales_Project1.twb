        <zone friendly-name='hor.info_container' h='99448' hidden-by-user='true' id='233' param='vert' type-v2='layout-flow' w='92875' x='7125' y='0'>
          <zone forceUpdate='true' h='61445' hidden-by-user='true' id='236' type-v2='text' w='92875' x='7125' y='0'>
            <formatted-text>
              <run bold='true' fontalignment='1' fontcolor='#00aa00' fontsize='15'>Welcome</run>
              <run fontalignment='1' fontcolor='#00aa00' fontsize='15'>Æ </run>
              <run fontalignment='1' fontcolor='#ffffff' fontsize='15'> &lt;Full Name&gt;</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run bold='true' fontalignment='1' fontcolor='#00aa00' fontsize='15'>_______________________________________________________________________</run>
              <run fontalignment='1'>Æ&#10;&#10;</run>
              <run fontalignment='1' fontcolor='#ffffff' fontsize='15'>Click on the chart to </run>
              <run bold='true' fontalignment='1' fontcolor='#00aa00' fontsize='15'>filter</run>
              <run fontalignment='1' fontcolor='#ffffff' fontsize='15'> the entire dashboard</run>
              <run fontalignment='1'>Æ&#10;&#10;</run>
              <run fontalignment='1' fontcolor='#ffffff' fontsize='15'>Click on the switch icon on top right corner to open the</run>
              <run bold='true' fontalignment='1' fontcolor='#00aa00' fontsize='15'> filter menu</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run bold='true' fontalignment='1' fontcolor='#00aa00' fontsize='15'>.</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#ffffff' fontsize='15'>This Sales Executive Summary Dashboard uses a dataset from</run>
              <run bold='true' fontalignment='1' fontcolor='#00aa00' fontsize='15'> Kaggle SuperStore Sales dataset.</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run bold='true' fontalignment='1' fontcolor='#00aa00' fontsize='15'>_______________________________________________________________________</run>
              <run fontalignment='1'>Æ&#10;&#10;</run>
              <run bold='true' fontalignment='1' fontcolor='#00aa00' fontsize='15'>Executive Summary:</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#ffffff' fontname='Benton Sans Book' fontsize='15'>“West region contributes the highest share of revenue and profit” </run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#ffffff' fontname='Benton Sans Book' fontsize='15'>“Technology → high profit, low volume” </run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#ffffff' fontname='Benton Sans Book' fontsize='15'>“3 states consistently generate losses — requires cost review”</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run bold='true' fontalignment='1' fontcolor='#00aa00' fontsize='15'>_______________________________________________________________________</run>
              <run fontalignment='1' fontcolor='#ffffff' fontname='Benton Sans Book' fontsize='15'>Æ </run>
              <run fontalignment='1'>Æ&#10;</run>
              <run bold='true' fontalignment='1' fontcolor='#00aa00' fontname='Benton Sans Book' fontsize='15'>Recommended Actions:</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#ffffff' fontname='Benton Sans Book' fontsize='15'>Focus on Technology category expansion </run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#ffffff' fontname='Benton Sans Book' fontsize='15'>Investigate loss-making states </run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#ffffff' fontname='Benton Sans Book' fontsize='15'>Optimize low-margin segments </run>
              <run fontalignment='1'>Æ&#10;&#10;&#10;</run>
              <run bold='true' fontalignment='1' fontcolor='#00aa00' fontsize='15'>Author: </run>
              <run bold='true' fontalignment='1' fontcolor='#ffffff' fontsize='15'>Timothy Maina</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='background-color' value='#000000ce' />
          </zone-style>
        </zone>
      </zones>
